# Application
APP_NAME="AI Document Intelligence"
DEBUG=True

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_doc_demo"

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# AWS S3 / Cloudflare R2
S3_BUCKET="your-bucket-name"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_ENDPOINT_URL=""  # For Cloudflare R2: https://ACCOUNT_ID.r2.cloudflarestorage.com

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"
OPENAI_MODEL_MINI="gpt-4o-mini"

# Anthropic Claude (Optional)
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"

# AWS Textract
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"
AWS_REGION="us-east-1"

# OCR Service Selection
OCR_SERVICE="textract"  # or "pytesseract"

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_MIME_TYPES=["application/pdf", "image/jpeg", "image/png", "image/jpg"]

# Server
PORT=8000
