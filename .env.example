# ========================================
# DocuMind 環境變數設定範例
# ========================================
# 使用方式：
#   1. 複製此檔案：cp .env.example .env
#   2. 填入你的 API Keys
#   3. 啟動服務：docker-compose up -d
# ========================================

# ========================================
# 檔案儲存設定
# ========================================
# 選擇儲存方式：
#   - "local" = 本地檔案系統（測試用，無需雲端服務）✅ 推薦
#   - "s3"    = AWS S3 或 Cloudflare R2（生產環境用）
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=/app/uploads

# AWS S3 / Cloudflare R2 設定（僅在 STORAGE_TYPE="s3" 時需要）
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=  # 留空 = AWS S3，填入 URL = Cloudflare R2

# ========================================
# AI 服務設定
# ========================================
# OpenAI API（AI 核心功能必需）
OPENAI_API_KEY=  # 👈 在此填入你的 OpenAI API Key (sk-...)
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_MINI=gpt-4o-mini

# Anthropic Claude（選用，目前未使用）
ANTHROPIC_API_KEY=

# ========================================
# OCR 文字辨識設定
# ========================================
# OCR 服務選擇：
#   - "pytesseract" = 免費本地 OCR（推薦測試用）✅ 推薦
#   - "textract"    = AWS Textract（需 AWS 憑證，付費）
OCR_SERVICE=pytesseract

# AWS Textract 設定（僅在 OCR_SERVICE="textract" 時需要）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
